# Copy this file to .env and fill in real values. NEVER commit a real .env file.

# Flask environment: development | testing | production
FLASK_ENV=development

# SQLAlchemy database URI. SQLite by default for local development.
DATABASE_URL=sqlite:///instance/app.db

# JWT signing key. Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=replace-me-with-a-long-random-string

# Fernet encryption key for secrets at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_ENCRYPTION_KEY=replace-me-with-a-fernet-key

# Directory where encrypted secret ciphertext files are stored.
SECRET_STORAGE_DIR=data/secrets

# How long share tokens stay valid, in seconds. Default: 1 hour.
SHARE_TOKEN_TTL_SECONDS=3600

# Optional: storage URI for Flask-Limiter. Defaults to in-memory.
# RATELIMIT_STORAGE_URI=memory://
